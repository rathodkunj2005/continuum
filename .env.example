# Optional: Claude Agent SDK (experimental UI)
ANTHROPIC_API_KEY=

# Graph / external knowledge (optional, experimental features)
# OPENAI_API_KEY=
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Evaluation UI: build with VITE_EVAL_UI=true to hide Meetings, Graph, Agent, etc.
# VITE_EVAL_UI=true

# Optional meeting recorder input override (macOS avfoundation audio index only).
# Leave unset for auto-detection. Setting `0` on some machines maps to `ZoomAudioDevice`,
# which often records silence.
# CONTINUUM_MEETING_AUDIO_DEVICE=2

# MCP transport mode:
# - local  (default): localhost-only, auth optional
# - tunnel: localhost bind + auth required + loopback bypass disabled
# - public: custom bind host + auth required
# CONTINUUM_MCP_MODE=local
# CONTINUUM_MCP_REQUIRE_AUTH=true
# CONTINUUM_MCP_ALLOW_LOOPBACK_AUTH_BYPASS=false
# CONTINUUM_MCP_ENABLE_TLS=false
# CONTINUUM_MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://claude.ai
# CONTINUUM_MCP_PUBLIC_BASE_URL=https://your-subdomain.trycloudflare.com

# App config is stored in the OS config directory (config.toml), including:
# - use_demo_data_only — pause live capture indexing; use seeded demo rows only
# - use_vlm — set false for a more stable OCR+LLM-only pipeline
# CLI: pass --demo-data-only to the Continuum binary to force demo mode for one session
