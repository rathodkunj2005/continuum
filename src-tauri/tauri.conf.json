{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "continuum",
    "version": "0.2.11",
    "identifier": "com.continuum.app",
    "build": {
        "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
        "devUrl": "http://127.0.0.1:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Continuum",
                "width": 900,
                "height": 700,
                "resizable": true,
                "fullscreen": false,
                "transparent": false,
                "decorations": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "dmg",
            "app"
        ],
        "resources": {
            "target/hermes-agent-bundle/": "hermes-agent/",
            "bundled-models/": "models/",
            "sidecars/parakeet_runner.py": "sidecars/parakeet_runner.py",
            "sidecars/whisper_gguf_runner.py": "sidecars/whisper_gguf_runner.py",
            "sidecars/orpheus_tts_runner.py": "sidecars/orpheus_tts_runner.py"
        },
        "icon": [
            "icons/icon.png",
            "icons/icon.icns"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist",
            "infoPlist": "Info.plist",
            "minimumSystemVersion": "13.0",
            "signingIdentity": "-"
        }
    }
}
